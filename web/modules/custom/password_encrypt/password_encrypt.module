<?php

/**
 * @file
 * Module file for password_encrypt.
 */
use Symfony\Component\HttpFoundation\RedirectResponse;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\Core\Url;
use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_help().
 */
function password_encrypt_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.password_encrypt':
      $output = '<h3>' . \Drupal::translation()->translate('About') . '</h3>';
      $output .= '<p>' . \Drupal::translation()->translate('This module encrypts the user password on user form submission. It prevents the propagation of plain password over the internet on user form submission.') . '</p>';
      $output .= '<h3>' . \Drupal::translation()->translate('Dependencies:') . '</h3>';
      $output .= '<ol><li>' . \Drupal::translation()->translate('OpenSSL extension.') . '</li>';
      $output .= '<li>' . \Drupal::translation()->translate('CryptoJS library.') . '</li></ol>';
      $output .= '<h3>' . \Drupal::translation()->translate('Installation:') . '</h3>';
      $output .= '<ol><li>' . \Drupal::translation()->translate('Download CryptoJS library from %crypto and extract it. Move rollups/aes.js to %path.', [
        '%crypto' => Url::fromUri('https://code.google.com/archive/p/crypto-js/downloads')->toString(),
        '%path' => 'sites/all/libraries/CryptoJS',
      ]) . '</li>';
      $output .= '<li>' . \Drupal::translation()->translate('Install and Enable Password Encrypt module.') . '</li>';
      $output .= '<li>' . \Drupal::translation()->translate('Clear cache.') . '</li></ol>';

      return $output;
  }
}

/**
 * Implements hook_page_attachments_alter().
 */

 function encryptSaltKey() {
  $salt = \Drupal::state()->get('password_encrypt.passkey');
  if (!$salt) {
    $salt = bin2hex(openssl_random_pseudo_bytes(8));
    \Drupal::state()->set('password_encrypt.passkey', $salt);
  }
  return $salt;
}

function password_encrypt_page_attachments_alter(array &$page) {
  $passkey = \Drupal::state()->get('password_encrypt.passkey');
  if (!$passkey) {
    $passkey = bin2hex(openssl_random_pseudo_bytes(8));
    \Drupal::state()->set('password_encrypt.passkey', $passkey);
  }

  $page['#attached']['drupalSettings']['password_encrypt']['passkey'] = $passkey;
  $page['#attached']['library'][] = 'password_encrypt/password_encrypt';
}



/**
 * Verifies CryptoJS library is present.
 */
function password_encrypt_library_check() {
  if (function_exists('libraries_get_libraries')) {
    $library = libraries_get_libraries();
    if (isset($library['CryptoJS'])) {
      return TRUE;
    }
  }
  elseif (file_exists('libraries/CryptoJS/aes.js')) {
    return TRUE;
  }
  return FALSE;
}

/**
 * Implements hook_form_alter().
 */
function password_encrypt_form_alter(array &$form, FormStateInterface &$form_state, $form_id) {
  if (in_array($form_id, ['user_login_form', 'user_login_block', 'user_register_form', 'user_form'])) {
    array_unshift($form['#validate'], 'password_encrypt_user_decrypt_password');
  }
}


function password_encrypt_user_decrypt_password(array &$form, FormStateInterface $form_state) {

  $passkey = \Drupal::state()->get('password_encrypt.passkey');
  if (!$passkey) {
    \Drupal::logger('password_encrypt')->error('Passkey not found.');
    return;
  }

  $input = $form_state->getUserInput();

  /*
   * -------------------------
   * 1) USERNAME DECRYPT
   * -------------------------
   */
  if (!empty($input['name'])) {

    \Drupal::logger('password_encrypt')->notice('Encrypted username received: @u', ['@u' => $input['name']]);

    $decrypted_user = password_encrypt_crypto_js_aes_decrypt($passkey, $input['name']);

    if ($decrypted_user === FALSE) {
      \Drupal::logger('password_encrypt')->error('Failed to decrypt username.');
    }
    else {
      $form_state->setValue('name', $decrypted_user);
      $input['name'] = $decrypted_user;
      $form_state->setUserInput($input);

      \Drupal::logger('password_encrypt')->notice('Username decrypted successfully: @u', ['@u' => $decrypted_user]);
    }
  }

  /*
   * -------------------------
   * 2) PASSWORD DECRYPT (your existing code)
   * -------------------------
   */
  if (!empty($input['pass'])) {

    $decrypted_pass = password_encrypt_crypto_js_aes_decrypt($passkey, $input['pass']);

    if ($decrypted_pass === FALSE) {
      \Drupal::logger('password_encrypt')->error('Failed to decrypt password.');
    }
    else {
      $form_state->setValue('pass', $decrypted_pass);
      $input['pass'] = $decrypted_pass;
      $form_state->setUserInput($input);

      \Drupal::logger('password_encrypt')->notice('Password decrypted successfully.');
    }
  }
}




function password_encrypt_crypto_js_aes_decrypt($passphrase, $jsonstring) {
  // Check if the passphrase is NULL.
  if ($passphrase === NULL) {
    \Drupal::logger('password_encrypt')->error('Decryption failed: passphrase is NULL.');
    return FALSE;
  }

  $cipher_text = base64_decode($jsonstring);

  // Check if the cipher text is valid and contains "Salted__" prefix.
  if (substr($cipher_text, 0, 8) != "Salted__") {
    \Drupal::logger('password_encrypt')->error('Decryption failed: Invalid cipher text.');
    return FALSE;
  }

  // Extract the salt from the cipher text.
  $salt = substr($cipher_text, 8, 8);

  // Ensure that a valid salt is used.
  if (empty($salt)) {
    \Drupal::logger('password_encrypt')->error('Decryption failed: Salt is empty.');
    return FALSE;
  }

  // Generate key and IV using the passphrase and salt.
  $key_and_iv = password_encrypt_generate_iv($passphrase, $salt);

  // Decrypt the data using the key and IV.
  $decrypt = openssl_decrypt(substr($cipher_text, 16), "aes-256-cbc", $key_and_iv["key"], OPENSSL_RAW_DATA, $key_and_iv["iv"]);

  return $decrypt;
}



function password_encrypt_generate_iv($password, $salt, $key_size = 8, $iv_length = 4, $iterations = 1, $algorithm = "md5") {
  $target_key_size = $key_size + $iv_length;
  $derived_bytes = "";
  $number_derived_words = 0;
  $block = ''; // Ensure $block is initialized as an empty string.
  $hasher = hash_init($algorithm);

  while ($number_derived_words < $target_key_size) {
    if (!empty($block)) { // Ensure that $block is not empty before passing to hash_update.
      hash_update($hasher, $block);
    }
    
    hash_update($hasher, $password);
    hash_update($hasher, $salt);
    $block = hash_final($hasher, TRUE);
    $hasher = hash_init($algorithm);
    
    // Iterations.
    for ($i = 1; $i < $iterations; $i++) {
      hash_update($hasher, $block);
      $block = hash_final($hasher, TRUE);
      $hasher = hash_init($algorithm);
    }
    
    $derived_bytes .= substr($block, 0, min(strlen($block), ($target_key_size - $number_derived_words) * 4));
    $number_derived_words += strlen($block) / 4;
  }
  
  return [
    "key" => substr($derived_bytes, 0, $key_size * 4),
    "iv"  => substr($derived_bytes, $key_size * 4, $iv_length * 4),
  ];
}


/**
 * Handle user login.
*/
function password_encrypt_user_login(\Drupal\user\UserInterface $account) {
  // Regenerate the passkey if needed.
  encryptSaltKey(); // Ensure the passkey exists after login.
  \Drupal::logger('password_encrypt')->notice('User logged in, passkey validated for user: @user.', ['@user' => $account->getAccountName()]);
}

// /**
//  * Handle user logout.
//  */
function password_encrypt_user_logout($account) {
  \Drupal::state()->delete('password_encrypt.passkey');
  
  \Drupal::service('cache.default')->deleteAll();
  \Drupal::service('cache.page')->deleteAll();
  \Drupal::service('cache.render')->deleteAll();
  \Drupal::service('cache.bootstrap')->deleteAll();
  \Drupal::service('cache.discovery')->deleteAll();
  
  \Drupal::logger('password_encrypt')->notice('Encryption passkey expired after logout.');
  
  $response = new RedirectResponse(Url::fromRoute('user.page')->toString()); // Redirect to user page.
  
}
