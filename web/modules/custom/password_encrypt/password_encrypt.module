<?php

/**
 * @file
 * Module file for password_encrypt.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Routing\RouteMatchInterface;

const PASSWORD_ENCRYPT_RSA_PRIVATE_KEY = 'password_encrypt.rsa_private_key';
const PASSWORD_ENCRYPT_RSA_PUBLIC_KEY = 'password_encrypt.rsa_public_key';

/**
 * Implements hook_help().
 */
function password_encrypt_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.password_encrypt':
      $output = '<h3>' . \Drupal::translation()->translate('About') . '</h3>';
      $output .= '<p>' . \Drupal::translation()->translate('This module encrypts login and password form fields in the browser with an RSA public key. The matching private key stays server-side and is used only to decrypt form values before Drupal validates them. HTTPS/TLS must still be enforced.') . '</p>';

      return $output;
  }
}

/**
 * Verifies the OpenSSL extension is present.
 */
function password_encrypt_library_check() {
  return extension_loaded('openssl');
}

/**
 * Implements hook_form_alter().
 */
function password_encrypt_form_alter(array &$form, FormStateInterface &$form_state, $form_id) {
  if (in_array($form_id, ['user_login_form', 'user_login_block', 'user_register_form', 'user_form'], TRUE)) {
    password_encrypt_attach_form_protection($form);
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for the user login form.
 */
function password_encrypt_form_user_login_form_alter(array &$form, FormStateInterface &$form_state, $form_id) {
  password_encrypt_attach_form_protection($form);
}

/**
 * Implements hook_form_FORM_ID_alter() for the user login block.
 */
function password_encrypt_form_user_login_block_alter(array &$form, FormStateInterface &$form_state, $form_id) {
  password_encrypt_attach_form_protection($form);
}

/**
 * Implements hook_form_FORM_ID_alter() for user registration.
 */
function password_encrypt_form_user_register_form_alter(array &$form, FormStateInterface &$form_state, $form_id) {
  password_encrypt_attach_form_protection($form);
}

/**
 * Implements hook_form_FORM_ID_alter() for user edit forms.
 */
function password_encrypt_form_user_form_alter(array &$form, FormStateInterface &$form_state, $form_id) {
  password_encrypt_attach_form_protection($form);
}

/**
 * Attaches encryption JS and decrypt validator to credential forms.
 */
function password_encrypt_attach_form_protection(array &$form) {
  $keys = password_encrypt_ensure_rsa_keys();
  if (!empty($keys['public_key'])) {
    $form['#attached']['drupalSettings']['password_encrypt']['publicKey'] = $keys['public_key'];
    $form['#attached']['library'][] = 'password_encrypt/password_encrypt';
  }

  if (empty($form['#validate']) || !is_array($form['#validate'])) {
    $form['#validate'] = [];
  }

  if (!in_array('password_encrypt_decrypt_form_values', $form['#validate'], TRUE)) {
    array_unshift($form['#validate'], 'password_encrypt_decrypt_form_values');
  }
}

/**
 * Ensures a server-side RSA keypair exists.
 */
function password_encrypt_ensure_rsa_keys() {
  $private_key = \Drupal::state()->get(PASSWORD_ENCRYPT_RSA_PRIVATE_KEY);
  $public_key = \Drupal::state()->get(PASSWORD_ENCRYPT_RSA_PUBLIC_KEY);

  if ($private_key && $public_key) {
    return [
      'private_key' => $private_key,
      'public_key' => $public_key,
    ];
  }

  if (!extension_loaded('openssl')) {
    \Drupal::logger('password_encrypt')->error('OpenSSL is required for RSA credential encryption.');
    return [];
  }

  $resource = openssl_pkey_new([
    'private_key_bits' => 4096,
    'private_key_type' => OPENSSL_KEYTYPE_RSA,
  ]);

  if (!$resource || !openssl_pkey_export($resource, $private_key)) {
    \Drupal::logger('password_encrypt')->error('Unable to generate RSA keypair.');
    return [];
  }

  $details = openssl_pkey_get_details($resource);
  if (empty($details['key'])) {
    \Drupal::logger('password_encrypt')->error('Unable to read generated RSA public key.');
    return [];
  }

  $public_key = $details['key'];
  \Drupal::state()->delete('password_encrypt.passkey');
  \Drupal::state()->set(PASSWORD_ENCRYPT_RSA_PRIVATE_KEY, $private_key);
  \Drupal::state()->set(PASSWORD_ENCRYPT_RSA_PUBLIC_KEY, $public_key);

  return [
    'private_key' => $private_key,
    'public_key' => $public_key,
  ];
}

/**
 * Decrypt encrypted login and password values before Drupal validation.
 */
function password_encrypt_decrypt_form_values(array &$form, FormStateInterface $form_state) {
  $input = $form_state->getUserInput();
  $changed = FALSE;

  foreach (['name', 'pass', 'current_pass'] as $key) {
    if (array_key_exists($key, $input)) {
      $plain_value_found = FALSE;
      $input[$key] = password_encrypt_decrypt_value($input[$key], $changed, $plain_value_found);
      if ($plain_value_found) {
        $form_state->setErrorByName($key, t('Credential encryption failed. Please reload the page and try again.'));
      }
      $form_state->setValue($key, $input[$key]);
    }
  }

  if ($changed) {
    $form_state->setUserInput($input);
    \Drupal::logger('password_encrypt')->notice('RSA encrypted credential form values decrypted before validation.');
  }
}

/**
 * Decrypt a value or nested password value.
 */
function password_encrypt_decrypt_value($value, &$changed, &$plain_value_found) {
  if (is_array($value)) {
    foreach ($value as $key => $item) {
      $value[$key] = password_encrypt_decrypt_value($item, $changed, $plain_value_found);
    }
    return $value;
  }

  if (!is_string($value) || $value === '') {
    return $value;
  }

  if (strpos($value, 'rsa:') !== 0) {
    $plain_value_found = TRUE;
    return $value;
  }

  $cipher_text = base64_decode(substr($value, 4), TRUE);
  if ($cipher_text === FALSE) {
    \Drupal::logger('password_encrypt')->error('Invalid RSA encrypted form value.');
    return $value;
  }

  $private_key = \Drupal::state()->get(PASSWORD_ENCRYPT_RSA_PRIVATE_KEY);
  if (!$private_key) {
    \Drupal::logger('password_encrypt')->error('RSA private key is missing.');
    return $value;
  }

  $plain_text = '';
  if (!openssl_private_decrypt($cipher_text, $plain_text, $private_key, OPENSSL_PKCS1_OAEP_PADDING)) {
    \Drupal::logger('password_encrypt')->error('Unable to decrypt RSA encrypted form value.');
    return $value;
  }

  $changed = TRUE;
  return $plain_text;
}

/**
 * Handle user login.
 */
function password_encrypt_user_login(\Drupal\user\UserInterface $account) {
  \Drupal::logger('password_encrypt')->notice('User logged in while Password Encrypt module is active: @user.', ['@user' => $account->getAccountName()]);
}

/**
 * Handle user logout.
 */
function password_encrypt_user_logout($account) {
  \Drupal::state()->delete('password_encrypt.passkey');
  \Drupal::logger('password_encrypt')->notice('Legacy AES passkey removed after logout.');
}
