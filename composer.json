{
    "name": "drupal/recommended-project",
    "description": "Project template for Drupal projects with a relocated document root",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://www.drupal.org/project/drupal",
    "support": {
        "docs": "https://www.drupal.org/docs/user_guide/en/index.html",
        "chat": "https://www.drupal.org/node/314178"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "composer/installers": "^2.0",
        "doctrine/annotations": "^1.13",
        "drupal/admin_toolbar": "3.4",
        "drupal/better_passwords": "^2.2",
        "drupal/blockgroup": "^2.0",
        "drupal/captcha": "^2.0",
        "drupal/colorbox": "2.0",
        "drupal/comment_notify": "1.4",
        "drupal/conditional_fields": "^4.0@alpha",
        "drupal/context": "^5.0@RC",
        "drupal/core-composer-scaffold": "^10",
        "drupal/core-project-message": "^10",
        "drupal/core-recommended": "^10",
        "drupal/csp": "^1.33",
        "drupal/ctools": "^4.1",
        "drupal/devel": "5.2",
        "drupal/email_registration": "1.4",
        "drupal/email_verification": "1.2",
        "drupal/entity": "^1.6",
        "drupal/eva": "3.0",
        "drupal/feeds": "^3.2",
        "drupal/field_tools": "^1.0@alpha",
        "drupal/field_validation": "1.1",
        "drupal/file_mime_validator": "^2.0",
        "drupal/fullcalendar_view": "^5.1",
        "drupal/google_analytics": "^4.0",
        "drupal/imce": "3.0",
        "drupal/inactive_autologout": "^3.0",
        "drupal/job_scheduler": "4.0",
        "drupal/libraries": "4.0",
        "drupal/login_destination": "^2.0@beta",
        "drupal/lpl": "^1.0",
        "drupal/menu_block": "1.10",
        "drupal/menu_link_content_visibility": "2.0",
        "drupal/menus_attribute": "1.3",
        "drupal/migrate_upgrade": "4.0",
        "drupal/mix": "^1.10",
        "drupal/node_export": "1.1",
        "drupal/openid_connect": "1.4",
        "drupal/paragraphs": "1.17",
        "drupal/password_policy": "^4.0",
        "drupal/pathauto": "1.12",
        "drupal/poll": "1.6",
        "drupal/push_notifications": "^1.0@alpha",
        "drupal/rdf": "2.0",
        "drupal/recaptcha": "^3.4",
        "drupal/redirect": "1.9",
        "drupal/redirect_after_logout": "1.3",
        "drupal/registration_role": "2.0",
        "drupal/rename_admin_paths": "^3.1",
        "drupal/rules": "^4.0",
        "drupal/securimage": "^9.1",
        "drupal/security_review": "3.0",
        "drupal/session_management": "^1.0",
        "drupal/shortcode": "^2.0",
        "drupal/simple_pass_reset": "1.2",
        "drupal/sitemap": "^2.5",
        "drupal/smtp": "^1.4",
        "drupal/switch_page_theme": "^4.0",
        "drupal/taxonomy_term_depth": "2.6",
        "drupal/token": "1.14",
        "drupal/upgrade_status": "4.2",
        "drupal/vendor_stream_wrapper": "^2.0",
        "drupal/views_bulk_operations": "4.2",
        "drupal/views_data_export": "1.4",
        "drupal/webform": "^6.2",
        "drupal/weight": "^3.6",
        "drupal/workbench": "1.4",
        "drupal/xmlsitemap": "1.5",
        "drupal/youtube": "2.0",
        "drush/drush": "^12.5"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "robloach/component-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ],
            "web/modules/custom/{$name}": [
                "type:drupal-custom-module"
            ],
            "web/profiles/custom/{$name}": [
                "type:drupal-custom-profile"
            ],
            "web/themes/custom/{$name}": [
                "type:drupal-custom-theme"
            ]
        },
        "drupal-core-project-message": {
            "include-keys": [
                "homepage",
                "support"
            ],
            "post-create-project-cmd-message": [
                "<bg=blue;fg=white>                                                         </>",
                "<bg=blue;fg=white>  Congratulations, you’ve installed the Drupal codebase  </>",
                "<bg=blue;fg=white>  from the drupal/recommended-project template!          </>",
                "<bg=blue;fg=white>                                                         </>",
                "",
                "<bg=yellow;fg=black>Next steps</>:",
                "  * Install the site: https://www.drupal.org/docs/installing-drupal",
                "  * Read the user guide: https://www.drupal.org/docs/user_guide/en/index.html",
                "  * Get support: https://www.drupal.org/support",
                "  * Get involved with the Drupal community:",
                "      https://www.drupal.org/getting-involved",
                "  * Remove the plugin that prints this message:",
                "      composer remove drupal/core-project-message"
            ]
        }
    }
}
